# Copy to apps/server/.env or repo root and adjust.

# Database
DB_TYPE=sqlite
DATABASE_URL=./data/store.db

# Storage (local MVP)
STORAGE_TYPE=local
STORAGE_LOCAL_DIR=./data/packages
# Public URL prefix for zip files (browser + CLI). Dev with Vite proxy:
STORAGE_LOCAL_BASE_URL=http://localhost:5173/files

# GitHub OAuth — create at https://github.com/settings/developers
# Authorization callback URL (dev): http://localhost:5173/api/v1/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:5173/api/v1/auth/github/callback

# Frontend (OAuth redirect after login)
FRONTEND_URL=http://localhost:5173

# JWT (min 16 chars)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

PORT=3000
NODE_ENV=development
