{
  "name": "xopc-store",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --parallel --filter @xopc-store/web --filter @xopc-store/server dev",
    "dev:server": "pnpm --filter @xopc-store/server dev",
    "dev:web": "pnpm --filter @xopc-store/web dev",
    "lint": "pnpm -r run lint",
    "db:generate": "pnpm --filter @xopc-store/server db:generate",
    "db:push": "pnpm --filter @xopc-store/server db:push",
    "upload-skills": "node scripts/upload-skills-to-store.mjs",
    "download-clawhub-top-100": "node scripts/download-clawhub-top-skills.mjs --limit 100 --out third-party/clawhub-top-100"
  },
  "engines": {
    "node": ">=22"
  }
}
